# second-brain-os API keys
#
# Fill in the values below and rename to .env (which is gitignored).
# scripts/install.sh prompts interactively for these — re-run with
# --reconfigure to rotate.

# Required:
ANTHROPIC_API_KEY=
# Used by: Ouros harness sub-LLM calls, FastEdit
# Get one: https://console.anthropic.com

EXA_API_KEY=
# Used by: exa MCP + /research, company-research, people-research skills
# Get one: https://exa.ai

NIA_API_KEY=
# Used by: NIA docs bridge (/autonomous-research)
# Get one: https://trynia.ai

# Optional:
HF_TOKEN=
# Used by: FastEdit model pull if the model is gated on Hugging Face
# Get one: https://huggingface.co/settings/tokens

ATLASSIAN_BASIC_AUTH=
# Used by: atlassian MCP (Jira, Confluence)
# Get one: https://id.atlassian.com/manage-profile/security/api-tokens
